---
import BaseLayout from "../layouts/BaseLayout.astro";
import releases from "../data/releases.json";
---

<BaseLayout title="Music — Vibin' Psybin and the Sunlight Band">
  <h1>Music</h1>
  <p class="muted">Every release, ordered newest first.</p>

  <div class="grid">
    {releases.map((r) => (
      <article class="release">
        <header>
          <h2>{r.title}</h2>
          <p class="meta">
            <span>{r.artist}</span> &middot;
            <span>{r.year}</span> &middot;
            <span class="type">{r.type}</span>
          </p>
        </header>
        {r.tracks && (
          <ol class="tracks">
            {r.tracks.map((t) => <li>{t}</li>)}
          </ol>
        )}
        {r.notes && <p class="notes">{r.notes}</p>}
        <div class="links">
          {r.appleMusicUrl && <a href={r.appleMusicUrl}>Apple Music</a>}
          {!r.appleMusicUrl && <span class="muted">Streaming links coming soon</span>}
        </div>
      </article>
    ))}
  </div>

  <style>
    .grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-top: 2rem;
    }
    @media (min-width: 720px) {
      .grid { grid-template-columns: 1fr 1fr; }
    }
    .release {
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 1.5rem;
      background: var(--bg-alt);
    }
    .release h2 {
      margin-top: 0;
      font-size: 1.5rem;
    }
    .meta {
      color: var(--fg-muted);
      font-size: 0.9rem;
      margin: 0.25rem 0 1rem;
    }
    .type {
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.75rem;
      color: var(--accent);
    }
    .tracks {
      padding-left: 1.25rem;
      margin: 0.5rem 0 1rem;
      color: var(--fg);
    }
    .tracks li { margin: 0.2rem 0; }
    .notes {
      font-style: italic;
      color: var(--fg-muted);
      margin: 0.5rem 0 1rem;
    }
    .links { margin-top: 0.5rem; }
  </style>
</BaseLayout>
