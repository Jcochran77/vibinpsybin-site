---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchSpotifyReleases } from "../lib/spotify";
import type { PlatformLinks } from "../lib/songlink";

// Pulled at build time. Falls back to src/data/releases.json when
// SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET are missing or the API errors.
const releases = await fetchSpotifyReleases();

function typeLabel(t: string) {
  return t === "ep" ? "EP" : t.charAt(0).toUpperCase() + t.slice(1);
}

// Display order is intentional: Spotify primary, Apple Music second
// (Odesli has near-100% Apple coverage for anything on Spotify), then the
// rest by general US listener share. Bandcamp comes from per-release
// overrides (data seam) so it lives outside PlatformLinks.
const PLATFORM_ORDER: { key: keyof PlatformLinks; label: string }[] = [
  { key: "spotify",      label: "Spotify" },
  { key: "appleMusic",   label: "Apple Music" },
  { key: "youtubeMusic", label: "YouTube Music" },
  { key: "tidal",        label: "Tidal" },
  { key: "amazonMusic",  label: "Amazon Music" },
  { key: "deezer",       label: "Deezer" },
  { key: "pandora",      label: "Pandora" },
  { key: "soundcloud",   label: "SoundCloud" },
];

// Build per-release dropdown entries: walk PLATFORM_ORDER, keep only the
// platforms we actually have a URL for, then append Bandcamp if present.
// Spotify always falls back to r.spotifyUrl when Odesli hasn't resolved yet.
function buildPlatformEntries(r: {
  spotifyUrl: string | null;
  bandcampUrl?: string | null;
  platformLinks?: PlatformLinks | null;
}): { label: string; href: string }[] {
  const entries: { label: string; href: string }[] = [];
  for (const p of PLATFORM_ORDER) {
    let href: string | null | undefined;
    if (p.key === "spotify") {
      href = r.platformLinks?.spotify ?? r.spotifyUrl;
    } else {
      href = r.platformLinks?.[p.key];
    }
    if (href) entries.push({ label: p.label, href });
  }
  if (r.bandcampUrl) entries.push({ label: "Bandcamp", href: r.bandcampUrl });
  return entries;
}
---

<BaseLayout title="Music — Vibin' Psybin and the Sunlight Band">
  <section class="band page-hero">
    <div class="wrap-narrow">
      <p class="eyebrow">Discography</p>
      <h1>Music</h1>
      <p class="lead muted">
        Every release, newest first. Solo work as <em>Psybin</em>, band records as <em>Vibin&rsquo; Psybin and the Sunlight Band</em>.
      </p>
    </div>
  </section>

  <section class="band releases">
    <div class="wrap">
      <div class="release-list">
        {releases.map((r, idx) => (
          <article class={`release release-${idx % 2 === 0 ? "left" : "right"}`}>
            <div class="release-cover">
              {r.coverUrl ? (
                <img
                  src={r.coverUrl}
                  alt={`${r.title} cover art`}
                  loading="lazy"
                  width="640"
                  height="640"
                />
              ) : (
                <div class="cover-placeholder">
                  <span class="cover-title">{r.title}</span>
                </div>
              )}
            </div>
            <div class="release-body">
              <p class="eyebrow">{typeLabel(r.type)} &middot; {r.year}</p>
              <h2>{r.title}</h2>
              <p class="artist">{r.artist}</p>
              {r.trackNames.length > 0 && (
                <ol class="tracks">
                  {r.trackNames.map((t) => <li>{t}</li>)}
                </ol>
              )}
              {r.notes && <p class="notes">{r.notes}</p>}
              <div class="links">
                {(() => {
                  const entries = buildPlatformEntries(r);
                  if (entries.length === 0) {
                    return <span class="muted coming">Streaming links coming soon</span>;
                  }
                  // Single-platform shortcut: skip the dropdown chrome and link
                  // directly to the one place this release exists.
                  if (entries.length === 1) {
                    const only = entries[0];
                    return (
                      <a
                        class="btn btn-solid listen-btn listen-btn-single"
                        href={only.href}
                        target="_blank"
                        rel="noopener"
                      >
                        Listen on {only.label}
                      </a>
                    );
                  }
                  // Multi-platform: "Listen" button toggles a dropdown.
                  // Each dropdown needs a unique id so the toggle script can
                  // pair button↔menu and so click-outside math works.
                  const ddId = `listen-dd-${idx}`;
                  return (
                    <div class="listen-dropdown" data-listen-dropdown>
                      <button
                        type="button"
                        class="btn btn-solid listen-btn"
                        aria-haspopup="menu"
                        aria-expanded="false"
                        aria-controls={ddId}
                        data-listen-toggle
                      >
                        Listen
                        <span class="listen-caret" aria-hidden="true">▾</span>
                      </button>
                      <ul
                        id={ddId}
                        class="listen-menu"
                        role="menu"
                        data-listen-menu
                        hidden
                      >
                        {entries.map((e) => (
                          <li role="none">
                            <a
                              role="menuitem"
                              class="listen-menu-item"
                              href={e.href}
                              target="_blank"
                              rel="noopener"
                            >
                              {e.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  );
                })()}
              </div>
              <p class="song-note">
                <a href={`/contact?re=${encodeURIComponent(r.title)}`}>
                  Drop Joe a line about this one →
                </a>
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    .song-note {
      margin: 1.25rem 0 0;
      font-size: 0.9rem;
    }
    .song-note a {
      color: var(--fg-muted);
      font-style: italic;
      letter-spacing: 0.02em;
    }
    .song-note a:hover {
      color: var(--accent);
    }

    .page-hero {
      padding: 4rem 0 2rem;
      text-align: center;
    }
    .lead {
      font-size: 1.1rem;
      max-width: 42rem;
      margin: 0.5rem auto 0;
    }

    .release-list {
      display: flex;
      flex-direction: column;
      gap: 4rem;
      margin-top: 2rem;
    }

    .release {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      align-items: center;
    }
    .release-cover {
      max-width: 400px;
      margin: 0 auto;
    }
    .release-cover img {
      width: 100%;
      height: auto;
      border-radius: 3px;
      box-shadow: 0 15px 35px rgba(0,0,0,0.5);
      transition: transform 0.4s ease;
      display: block;
    }
    .release:hover .release-cover img {
      transform: scale(1.02);
    }
    .cover-placeholder {
      aspect-ratio: 1 / 1;
      background: linear-gradient(135deg, var(--bg-alt) 0%, var(--bg-elev) 100%);
      border: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cover-placeholder::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 30% 30%, rgba(78,205,196,0.1) 0%, transparent 60%);
    }
    .cover-title {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      color: var(--fg-muted);
      position: relative;
    }

    .release-body .eyebrow {
      color: var(--accent-2);
    }
    .release-body h2 {
      margin-top: 0.25rem;
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    }
    .artist {
      color: var(--fg-muted);
      font-style: italic;
      margin: 0 0 1rem;
    }
    .tracks {
      list-style: none;
      padding: 0;
      margin: 1rem 0;
      counter-reset: track;
      border-top: 1px solid var(--line-soft);
    }
    .tracks li {
      counter-increment: track;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--line-soft);
      font-family: var(--font-sans);
      color: var(--fg);
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }
    .tracks li::before {
      content: counter(track, decimal-leading-zero);
      color: var(--accent-2);
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      min-width: 1.5em;
    }
    .notes {
      color: var(--fg-muted);
      font-style: italic;
      margin: 1rem 0 1.5rem;
    }
    .links { margin-top: 1rem; }
    .coming { font-size: 0.9rem; font-style: italic; }

    /* Single "Listen" button + dropdown menu. Replaces the old multi-button
       row to cut visual clutter. */
    .listen-dropdown {
      position: relative;
      display: inline-block;
    }
    .listen-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.25rem;
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      cursor: pointer;
    }
    .listen-btn-single {
      /* Used when only one platform resolved — just a direct link button. */
      display: inline-flex;
    }
    .listen-caret {
      font-size: 0.7rem;
      line-height: 1;
      transition: transform 0.2s ease;
    }
    .listen-dropdown[data-open="true"] .listen-caret {
      transform: rotate(180deg);
    }
    .listen-menu {
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 0;
      z-index: 20;
      min-width: 14rem;
      list-style: none;
      padding: 0.4rem;
      margin: 0;
      background: var(--bg-elev, #14111c);
      border: 1px solid var(--line);
      border-radius: 6px;
      box-shadow:
        0 18px 40px rgba(0, 0, 0, 0.55),
        0 0 0 1px rgba(180, 90, 220, 0.08) inset;
      /* psychedelic accent: subtle violet→magenta edge glow */
      background-image:
        linear-gradient(180deg, rgba(120, 80, 200, 0.06) 0%, rgba(0, 0, 0, 0) 60%);
    }
    .listen-menu[hidden] { display: none; }
    .listen-menu-item {
      display: block;
      padding: 0.55rem 0.85rem;
      font-family: var(--font-sans);
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      color: var(--fg);
      text-decoration: none;
      border-radius: 4px;
      transition: background 0.15s ease, color 0.15s ease;
    }
    .listen-menu-item:hover,
    .listen-menu-item:focus-visible {
      background: rgba(180, 90, 220, 0.12);
      color: var(--accent-2, #f0a020);
      outline: none;
    }
    .listen-menu-item:focus-visible {
      box-shadow: 0 0 0 1px var(--accent-2, #f0a020);
    }
    /* First item (Spotify in normal case) gets a subtle highlight to keep
       the "primary" affordance Joe had before. */
    .listen-menu li:first-child .listen-menu-item {
      color: var(--accent-2, #f0a020);
    }

    @media (min-width: 760px) {
      .release {
        grid-template-columns: 1fr 1.3fr;
        gap: 3.5rem;
      }
      .release-right {
        grid-template-columns: 1.3fr 1fr;
      }
      .release-right .release-cover {
        order: 2;
      }
      .release-cover { max-width: none; }
    }
  </style>

  <script>
    // Listen-dropdown behavior: toggle on click/Enter/Space, close on Esc
    // and on outside click. Pure vanilla, no UI lib.
    (() => {
      const dropdowns = document.querySelectorAll<HTMLElement>("[data-listen-dropdown]");
      if (dropdowns.length === 0) return;

      function closeAll(except?: HTMLElement) {
        dropdowns.forEach((dd) => {
          if (dd === except) return;
          const btn = dd.querySelector<HTMLButtonElement>("[data-listen-toggle]");
          const menu = dd.querySelector<HTMLElement>("[data-listen-menu]");
          if (!btn || !menu) return;
          dd.removeAttribute("data-open");
          btn.setAttribute("aria-expanded", "false");
          menu.hidden = true;
        });
      }

      dropdowns.forEach((dd) => {
        const btn = dd.querySelector<HTMLButtonElement>("[data-listen-toggle]");
        const menu = dd.querySelector<HTMLElement>("[data-listen-menu]");
        if (!btn || !menu) return;

        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const open = dd.getAttribute("data-open") === "true";
          if (open) {
            dd.removeAttribute("data-open");
            btn.setAttribute("aria-expanded", "false");
            menu.hidden = true;
          } else {
            closeAll(dd);
            dd.setAttribute("data-open", "true");
            btn.setAttribute("aria-expanded", "true");
            menu.hidden = false;
          }
        });

        // Esc closes and returns focus to the toggle.
        dd.addEventListener("keydown", (e) => {
          if (e.key === "Escape") {
            if (dd.getAttribute("data-open") === "true") {
              dd.removeAttribute("data-open");
              btn.setAttribute("aria-expanded", "false");
              menu.hidden = true;
              btn.focus();
            }
          }
        });
      });

      // Click outside any dropdown -> close all.
      document.addEventListener("click", (e) => {
        const target = e.target as Node | null;
        if (!target) return closeAll();
        for (const dd of Array.from(dropdowns)) {
          if (dd.contains(target)) return;
        }
        closeAll();
      });
    })();
  </script>
</BaseLayout>
