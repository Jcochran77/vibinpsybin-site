---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchSpotifyReleases } from "../lib/spotify";
import type { PlatformLinks } from "../lib/songlink";

// Pulled at build time. Falls back to src/data/releases.json when
// SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET are missing or the API errors.
const releases = await fetchSpotifyReleases();

function typeLabel(t: string) {
  return t === "ep" ? "EP" : t.charAt(0).toUpperCase() + t.slice(1);
}

// Display order is intentional: Spotify primary, Apple Music second
// (Odesli has near-100% Apple coverage for anything on Spotify), then the
// rest by general US listener share.
const SECONDARY_PLATFORMS: { key: keyof PlatformLinks; label: string }[] = [
  { key: "appleMusic",   label: "Apple Music" },
  { key: "youtubeMusic", label: "YouTube Music" },
  { key: "tidal",        label: "Tidal" },
  { key: "amazonMusic",  label: "Amazon Music" },
  { key: "deezer",       label: "Deezer" },
  { key: "pandora",      label: "Pandora" },
  { key: "soundcloud",   label: "SoundCloud" },
];
---

<BaseLayout title="Music — Vibin' Psybin and the Sunlight Band">
  <section class="band page-hero">
    <div class="wrap-narrow">
      <p class="eyebrow">Discography</p>
      <h1>Music</h1>
      <p class="lead muted">
        Every release, newest first. Solo work as <em>Psybin</em>, band records as <em>Vibin&rsquo; Psybin and the Sunlight Band</em>.
      </p>
    </div>
  </section>

  <section class="band releases">
    <div class="wrap">
      <div class="release-list">
        {releases.map((r, idx) => (
          <article class={`release release-${idx % 2 === 0 ? "left" : "right"}`}>
            <div class="release-cover">
              {r.coverUrl ? (
                <img
                  src={r.coverUrl}
                  alt={`${r.title} cover art`}
                  loading="lazy"
                  width="640"
                  height="640"
                />
              ) : (
                <div class="cover-placeholder">
                  <span class="cover-title">{r.title}</span>
                </div>
              )}
            </div>
            <div class="release-body">
              <p class="eyebrow">{typeLabel(r.type)} &middot; {r.year}</p>
              <h2>{r.title}</h2>
              <p class="artist">{r.artist}</p>
              {r.trackNames.length > 0 && (
                <ol class="tracks">
                  {r.trackNames.map((t) => <li>{t}</li>)}
                </ol>
              )}
              {r.notes && <p class="notes">{r.notes}</p>}
              <div class="links">
                {r.spotifyUrl ? (
                  <div class="platform-row">
                    {/* Primary: Spotify */}
                    <a
                      class="btn btn-solid platform-btn platform-primary"
                      href={r.platformLinks?.spotify ?? r.spotifyUrl}
                      target="_blank"
                      rel="noopener"
                    >
                      Listen on Spotify
                    </a>
                    {/* Secondary platforms — only render when Odesli resolved a URL */}
                    {r.platformLinks && SECONDARY_PLATFORMS.map((p) => {
                      const href = r.platformLinks?.[p.key];
                      if (!href) return null;
                      return (
                        <a
                          class="btn platform-btn platform-secondary"
                          href={href}
                          target="_blank"
                          rel="noopener"
                        >
                          {p.label}
                        </a>
                      );
                    })}
                    {/* Bandcamp from per-release overrides (data seam for later) */}
                    {r.bandcampUrl && (
                      <a
                        class="btn platform-btn platform-secondary"
                        href={r.bandcampUrl}
                        target="_blank"
                        rel="noopener"
                      >
                        Bandcamp
                      </a>
                    )}
                  </div>
                ) : (
                  <span class="muted coming">Streaming links coming soon</span>
                )}
              </div>
              <p class="song-note">
                <a href={`/contact?re=${encodeURIComponent(r.title)}`}>
                  Drop Joe a line about this one →
                </a>
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    .song-note {
      margin: 1.25rem 0 0;
      font-size: 0.9rem;
    }
    .song-note a {
      color: var(--fg-muted);
      font-style: italic;
      letter-spacing: 0.02em;
    }
    .song-note a:hover {
      color: var(--accent);
    }

    .page-hero {
      padding: 4rem 0 2rem;
      text-align: center;
    }
    .lead {
      font-size: 1.1rem;
      max-width: 42rem;
      margin: 0.5rem auto 0;
    }

    .release-list {
      display: flex;
      flex-direction: column;
      gap: 4rem;
      margin-top: 2rem;
    }

    .release {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      align-items: center;
    }
    .release-cover {
      max-width: 400px;
      margin: 0 auto;
    }
    .release-cover img {
      width: 100%;
      height: auto;
      border-radius: 3px;
      box-shadow: 0 15px 35px rgba(0,0,0,0.5);
      transition: transform 0.4s ease;
      display: block;
    }
    .release:hover .release-cover img {
      transform: scale(1.02);
    }
    .cover-placeholder {
      aspect-ratio: 1 / 1;
      background: linear-gradient(135deg, var(--bg-alt) 0%, var(--bg-elev) 100%);
      border: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cover-placeholder::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 30% 30%, rgba(78,205,196,0.1) 0%, transparent 60%);
    }
    .cover-title {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      color: var(--fg-muted);
      position: relative;
    }

    .release-body .eyebrow {
      color: var(--accent-2);
    }
    .release-body h2 {
      margin-top: 0.25rem;
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    }
    .artist {
      color: var(--fg-muted);
      font-style: italic;
      margin: 0 0 1rem;
    }
    .tracks {
      list-style: none;
      padding: 0;
      margin: 1rem 0;
      counter-reset: track;
      border-top: 1px solid var(--line-soft);
    }
    .tracks li {
      counter-increment: track;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--line-soft);
      font-family: var(--font-sans);
      color: var(--fg);
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }
    .tracks li::before {
      content: counter(track, decimal-leading-zero);
      color: var(--accent-2);
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      min-width: 1.5em;
    }
    .notes {
      color: var(--fg-muted);
      font-style: italic;
      margin: 1rem 0 1.5rem;
    }
    .links { margin-top: 1rem; }
    .coming { font-size: 0.9rem; font-style: italic; }

    /* Multi-platform picker: wraps cleanly on narrow viewports. */
    .platform-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      align-items: center;
    }
    .platform-btn {
      /* shrink the standard .btn slightly so 8 fit comfortably on mobile */
      padding: 0.6rem 1rem;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
    }
    .platform-primary {
      /* keep primary visually weighted */
      padding: 0.75rem 1.25rem;
      font-size: 0.8rem;
    }
    .platform-secondary {
      border-color: var(--line);
      color: var(--fg-muted);
    }
    .platform-secondary:hover {
      background: transparent;
      border-color: var(--accent-2);
      color: var(--accent-2);
    }

    @media (min-width: 760px) {
      .release {
        grid-template-columns: 1fr 1.3fr;
        gap: 3.5rem;
      }
      .release-right {
        grid-template-columns: 1.3fr 1fr;
      }
      .release-right .release-cover {
        order: 2;
      }
      .release-cover { max-width: none; }
    }
  </style>
</BaseLayout>
