---
import BaseLayout from "../layouts/BaseLayout.astro";
import shows from "../data/shows.json";

const now = new Date();
const upcoming = shows
  .filter((s) => new Date(s.date) >= now)
  .sort((a, b) => +new Date(a.date) - +new Date(b.date));
const past = shows
  .filter((s) => new Date(s.date) < now)
  .sort((a, b) => +new Date(b.date) - +new Date(a.date));

function formatDate(iso: string) {
  const d = new Date(iso);
  return {
    day: d.toLocaleDateString("en-US", { weekday: "short" }),
    date: d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }),
    time: d.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" }),
  };
}
---

<BaseLayout title="Shows — Vibin' Psybin and the Sunlight Band">
  <h1>Shows</h1>

  <section>
    <h2>Upcoming</h2>
    {upcoming.length === 0 ? (
      <p class="muted">No shows on the books right now. Sign up for updates on the home page.</p>
    ) : (
      <ul class="shows">
        {upcoming.map((s) => {
          const f = formatDate(s.date);
          return (
            <li class="show">
              <div class="date">
                <span class="day">{f.day}</span>
                <span class="date-main">{f.date}</span>
                <span class="time">{f.time}</span>
              </div>
              <div class="details">
                <p class="venue">{s.venue}</p>
                <p class="city">{s.city}</p>
                {s.notes && <p class="notes">{s.notes}</p>}
              </div>
              <div class="actions">
                {s.ticketUrl && <a class="btn" href={s.ticketUrl}>Tickets</a>}
                {s.appleMusicUrl && <a href={s.appleMusicUrl}>Apple</a>}
                {s.spotifyUrl && <a href={s.spotifyUrl}>Spotify</a>}
              </div>
            </li>
          );
        })}
      </ul>
    )}
  </section>

  {past.length > 0 && (
    <section>
      <h2>Past shows</h2>
      <ul class="shows past">
        {past.map((s) => {
          const f = formatDate(s.date);
          return (
            <li class="show">
              <div class="date">
                <span class="date-main">{f.date}</span>
              </div>
              <div class="details">
                <p class="venue">{s.venue}</p>
                <p class="city">{s.city}</p>
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <p class="api-note muted">
    Shows are currently tracked manually. In a future release we&rsquo;ll pull live from Bandsintown.
  </p>

  <style>
    .shows {
      list-style: none;
      padding: 0;
      margin: 1.5rem 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .show {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
      padding: 1.25rem;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: var(--bg-alt);
    }
    @media (min-width: 720px) {
      .show {
        grid-template-columns: 170px 1fr auto;
        align-items: center;
        gap: 1.5rem;
      }
    }
    .date {
      display: flex;
      flex-direction: column;
      color: var(--accent);
      font-family: ui-sans-serif, system-ui, sans-serif;
    }
    .day {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }
    .date-main { font-size: 1.25rem; font-weight: 600; }
    .time { color: var(--fg-muted); font-size: 0.9rem; }
    .venue { margin: 0; font-size: 1.15rem; font-weight: 600; color: var(--fg); }
    .city { margin: 0.15rem 0; color: var(--fg-muted); }
    .notes { margin: 0.3rem 0 0; font-style: italic; color: var(--fg-muted); font-size: 0.9rem; }
    .actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .btn {
      display: inline-block;
      padding: 0.5rem 1rem;
      border: 1px solid var(--accent);
      color: var(--accent);
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.85rem;
      font-family: ui-sans-serif, system-ui, sans-serif;
    }
    .btn:hover {
      background: var(--accent);
      color: var(--bg);
      text-decoration: none;
    }
    .past .show {
      opacity: 0.6;
    }
    .api-note {
      font-style: italic;
      margin-top: 2rem;
      font-size: 0.85rem;
    }
  </style>
</BaseLayout>
