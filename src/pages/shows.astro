---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchShows, type NormalizedShow } from "../lib/bandsintown";
import bandPhoto from "../assets/photos/band-on-stage.jpg";

// Pulled at BUILD time from Bandsintown. Rebuild the site to refresh.
const allShows = await fetchShows("all");
const now = new Date();
const upcoming = allShows.filter((s) => new Date(s.datetime) >= now);
const past = allShows
  .filter((s) => new Date(s.datetime) < now)
  .sort((a, b) => +new Date(b.datetime) - +new Date(a.datetime));

function formatDate(iso: string) {
  const d = new Date(iso);
  return {
    day: d.toLocaleDateString("en-US", { weekday: "short" }),
    dayLong: d.toLocaleDateString("en-US", { weekday: "long" }),
    month: d.toLocaleDateString("en-US", { month: "short" }).toUpperCase(),
    dayNum: d.getDate(),
    year: d.getFullYear(),
    time: d.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" }),
  };
}
---

<BaseLayout title="Shows — Vibin' Psybin and the Sunlight Band">
  <section class="band page-hero">
    <div class="hero-bg">
      <Image
        src={bandPhoto}
        alt=""
        widths={[900, 1440, 1920]}
        sizes="100vw"
        loading="eager"
        class="hero-img"
      />
      <div class="hero-overlay" aria-hidden="true"></div>
    </div>
    <div class="wrap-narrow hero-content">
      <p class="eyebrow">Live</p>
      <h1>Shows</h1>
      <p class="lead">Catch us on a stage somewhere.</p>
    </div>
  </section>

  <section class="band">
    <div class="wrap">
      <h2>Upcoming</h2>
      {upcoming.length === 0 ? (
        <p class="empty muted">
          Nothing on the books right now. <a href="/">Sign up for the list</a> to hear about the next one.
        </p>
      ) : (
        <ul class="shows">
          {upcoming.map((s) => {
            const f = formatDate(s.datetime);
            return (
              <li class="show">
                <div class="date-col">
                  <span class="month">{f.month}</span>
                  <span class="day-num">{f.dayNum}</span>
                  <span class="weekday">{f.dayLong}</span>
                </div>
                <div class="details">
                  <p class="venue">{s.venue}</p>
                  <p class="city">{s.city} &middot; {f.time}</p>
                  {s.lineup && s.lineup.length > 1 && (
                    <p class="lineup">
                      with {s.lineup.filter((a) => a !== "Vibin' Psybin and the Sunlight Band").join(", ")}
                    </p>
                  )}
                  {s.soldOut && <p class="sold-out">SOLD OUT</p>}
                </div>
                <div class="actions">
                  {s.ticketUrl && !s.soldOut && <a class="btn btn-solid" href={s.ticketUrl}>Tickets</a>}
                  {s.bandsintownUrl && <a class="link" href={s.bandsintownUrl}>Details →</a>}
                </div>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>

  {past.length > 0 && (
    <section class="band past-section">
      <div class="wrap">
        <h2>Past shows</h2>
        <ul class="shows shows-past">
          {past.map((s) => {
            const f = formatDate(s.datetime);
            return (
              <li class="show show-past">
                <div class="date-col">
                  <span class="month">{f.month}</span>
                  <span class="day-num">{f.dayNum}</span>
                  <span class="weekday">{f.year}</span>
                </div>
                <div class="details">
                  <p class="venue">{s.venue}</p>
                  <p class="city">{s.city}</p>
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  <section class="band api-note-section">
    <div class="wrap-narrow">
      <p class="api-note muted">
        Shows pulled live from <a href="https://www.bandsintown.com/a/15635129">Bandsintown</a> at build time. Follow there to get notified.
      </p>
    </div>
  </section>

  <style>
    .page-hero {
      position: relative;
      min-height: 40vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
      padding: 4rem 0;
      border-top: none;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .hero-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(11,9,18,0.7) 0%, rgba(11,9,18,0.88) 100%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
    }
    .lead {
      font-size: 1.15rem;
      color: var(--fg-muted);
      margin: 0.5rem 0 0;
    }

    .empty {
      text-align: center;
      padding: 3rem 1rem;
      border: 1px dashed var(--line);
      border-radius: 4px;
      margin-top: 1.5rem;
    }

    .shows {
      list-style: none;
      padding: 0;
      margin: 2rem 0 0;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .show {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 1.75rem 0;
      border-top: 1px solid var(--line);
      transition: background 0.2s ease;
    }
    .show:last-child { border-bottom: 1px solid var(--line); }
    .show:hover {
      background: linear-gradient(90deg, transparent, rgba(78,205,196,0.03), transparent);
    }

    .date-col {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding-left: 1rem;
      border-left: 3px solid var(--accent-2);
    }
    .month {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      color: var(--accent-2);
    }
    .day-num {
      font-family: var(--font-serif);
      font-size: 2.75rem;
      line-height: 1;
      color: var(--fg);
      margin: 0.1rem 0;
    }
    .weekday {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: var(--fg-muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .venue {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      color: var(--fg);
      margin: 0;
      line-height: 1.2;
    }
    .city {
      color: var(--fg-muted);
      font-size: 0.95rem;
      margin: 0.3rem 0 0;
    }
    .lineup {
      margin: 0.5rem 0 0;
      font-style: italic;
      color: var(--fg-muted);
      font-size: 0.95rem;
    }
    .sold-out {
      margin: 0.6rem 0 0;
      font-family: var(--font-sans);
      font-size: 0.8rem;
      font-weight: 700;
      color: #f2806b;
      letter-spacing: 0.15em;
    }

    .actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .link {
      font-size: 0.9rem;
      color: var(--fg-muted);
    }
    .link:hover { color: var(--accent); }

    .past-section .show-past {
      opacity: 0.55;
      padding: 1.25rem 0;
    }
    .past-section .show-past .day-num { font-size: 2rem; }
    .past-section .show-past .venue { font-size: 1.2rem; }

    .api-note {
      font-style: italic;
      font-size: 0.9rem;
      text-align: center;
      margin: 2rem 0 0;
    }
    .api-note-section { padding-bottom: 2rem; }

    @media (min-width: 760px) {
      .show {
        grid-template-columns: 170px 1fr auto;
        align-items: center;
        gap: 2.5rem;
        padding: 2rem 0;
      }
    }
  </style>
</BaseLayout>
