---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchShows, type NormalizedShow } from "../lib/bandsintown";

// Pulled at BUILD time from Bandsintown. Rebuild the site to refresh.
const allShows = await fetchShows("all");
const now = new Date();
const upcoming = allShows.filter((s) => new Date(s.datetime) >= now);
const past = allShows
  .filter((s) => new Date(s.datetime) < now)
  .sort((a, b) => +new Date(b.datetime) - +new Date(a.datetime));

function formatDate(iso: string) {
  const d = new Date(iso);
  return {
    day: d.toLocaleDateString("en-US", { weekday: "short" }),
    date: d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }),
    time: d.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" }),
  };
}

function renderShow(s: NormalizedShow, pastShow = false) {
  const f = formatDate(s.datetime);
  return { s, f, pastShow };
}

const upcomingRendered = upcoming.map((s) => renderShow(s));
const pastRendered = past.map((s) => renderShow(s, true));
---

<BaseLayout title="Shows — Vibin' Psybin and the Sunlight Band">
  <h1>Shows</h1>

  <section>
    <h2>Upcoming</h2>
    {upcomingRendered.length === 0 ? (
      <p class="muted">No shows on the books right now. Sign up on the home page to hear about the next one.</p>
    ) : (
      <ul class="shows">
        {upcomingRendered.map(({ s, f }) => (
          <li class="show">
            <div class="date">
              <span class="day">{f.day}</span>
              <span class="date-main">{f.date}</span>
              <span class="time">{f.time}</span>
            </div>
            <div class="details">
              <p class="venue">{s.venue}</p>
              <p class="city">{s.city}</p>
              {s.lineup && s.lineup.length > 1 && (
                <p class="lineup">with {s.lineup.filter((a) => a !== "Vibin' Psybin and the Sunlight Band").join(", ")}</p>
              )}
              {s.soldOut && <p class="sold-out">SOLD OUT</p>}
            </div>
            <div class="actions">
              {s.ticketUrl && !s.soldOut && <a class="btn" href={s.ticketUrl}>Tickets</a>}
              <a class="link" href={s.bandsintownUrl}>Details</a>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  {pastRendered.length > 0 && (
    <section>
      <h2>Past shows</h2>
      <ul class="shows past">
        {pastRendered.map(({ s, f }) => (
          <li class="show">
            <div class="date">
              <span class="date-main">{f.date}</span>
            </div>
            <div class="details">
              <p class="venue">{s.venue}</p>
              <p class="city">{s.city}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  <p class="api-note muted">
    Shows pulled live from <a href="https://www.bandsintown.com/a/15635129">Bandsintown</a>. Site rebuilds when Joe adds a date.
  </p>

  <style>
    .shows {
      list-style: none;
      padding: 0;
      margin: 1.5rem 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .show {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
      padding: 1.25rem;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: var(--bg-alt);
    }
    @media (min-width: 720px) {
      .show {
        grid-template-columns: 170px 1fr auto;
        align-items: center;
        gap: 1.5rem;
      }
    }
    .date {
      display: flex;
      flex-direction: column;
      color: var(--accent);
      font-family: ui-sans-serif, system-ui, sans-serif;
    }
    .day {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }
    .date-main { font-size: 1.25rem; font-weight: 600; }
    .time { color: var(--fg-muted); font-size: 0.9rem; }
    .venue { margin: 0; font-size: 1.15rem; font-weight: 600; color: var(--fg); }
    .city { margin: 0.15rem 0; color: var(--fg-muted); }
    .lineup { margin: 0.3rem 0 0; font-style: italic; color: var(--fg-muted); font-size: 0.9rem; }
    .sold-out {
      margin: 0.5rem 0 0;
      font-family: ui-sans-serif, system-ui, sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      color: #e55;
      letter-spacing: 0.1em;
    }
    .actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .btn {
      display: inline-block;
      padding: 0.5rem 1rem;
      border: 1px solid var(--accent);
      color: var(--accent);
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.85rem;
      font-family: ui-sans-serif, system-ui, sans-serif;
    }
    .btn:hover {
      background: var(--accent);
      color: var(--bg);
      text-decoration: none;
    }
    .link {
      font-size: 0.9rem;
      color: var(--fg-muted);
    }
    .past .show { opacity: 0.6; }
    .api-note { font-style: italic; margin-top: 2rem; font-size: 0.85rem; }
  </style>
</BaseLayout>
