---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import circleLogo from "../assets/logos/vpsb-circle-logo.png";
---

<BaseLayout
  title="Subscribe — Vibin' Psybin and the Sunlight Band"
  description="Get an email when there's new music, a new video, or a show worth knowing about. No spam, no algorithm."
>
  <section class="band subscribe-hero">
    <div class="wrap-narrow center">
      <Image
        src={circleLogo}
        alt=""
        widths={[140, 220]}
        sizes="140px"
        class="mark"
      />
      <p class="eyebrow">Stay close</p>
      <h1>One email.<br/>Only when it matters.</h1>
      <p class="lead">
        New music. New videos. New shows. New merch. <em>That's it.</em>
      </p>

      <form id="email-signup" action="/api/subscribe" method="POST" class="form">
        <label for="email" class="sr-only">Email address</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="your@email.com"
        />
        <button type="submit" class="btn btn-solid">Sign me up</button>
      </form>
      <p class="form-msg" id="form-msg" aria-live="polite"></p>
    </div>
  </section>

  <section class="band promise-section">
    <div class="wrap-narrow promise">
      <div class="col">
        <h2 class="col-title">What you'll get</h2>
        <ul>
          <li>Heads up when a new single, EP, or record drops</li>
          <li>Music videos and live studio cuts</li>
          <li>Shows in your area before they sell out</li>
          <li>New merch drops</li>
          <li>The occasional handwritten note in the CD</li>
        </ul>
      </div>
      <div class="col">
        <h2 class="col-title">What you <em>won't</em> get</h2>
        <ul class="wont">
          <li>Daily anything</li>
          <li>"Engagement" content</li>
          <li>Ads, affiliate links, sponsorships</li>
          <li>Your data sold, ever</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="band signoff">
    <div class="wrap-narrow center">
      <p class="mantra">
        No tracking. No ads. No algorithm.
        <br/><em>Just the music.</em>
      </p>
    </div>
  </section>

  <style>
    .subscribe-hero {
      padding: 4rem 0 2rem;
      text-align: center;
    }
    .center { text-align: center; }
    .mark {
      width: 100px;
      height: auto;
      filter: invert(1) brightness(0.95);
      opacity: 0.85;
      margin: 0 auto 1.5rem;
      display: block;
    }
    h1 {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      line-height: 1.05;
      margin: 0.5rem auto 1rem;
    }
    .lead {
      font-size: 1.2rem;
      color: var(--fg-muted);
      font-style: italic;
      max-width: 32rem;
      margin: 0.5rem auto 2.5rem;
    }
    .lead em {
      color: var(--accent);
      font-style: italic;
    }

    .form {
      display: flex;
      gap: 0.5rem;
      max-width: 32rem;
      margin: 0 auto;
      flex-wrap: wrap;
      justify-content: center;
      padding: 1.25rem;
      background: var(--bg-alt);
      border: 1px solid var(--line);
      border-radius: 4px;
      position: relative;
      box-shadow:
        0 0 60px rgba(255,62,136,0.08),
        0 0 30px rgba(78,205,255,0.06);
    }
    .form::before {
      content: "";
      position: absolute;
      top: -1px; left: -1px; right: -1px;
      height: 2px;
      background: linear-gradient(90deg, var(--magenta), var(--violet), var(--electric));
      border-radius: 4px 4px 0 0;
    }
    .form input {
      flex: 1 1 18rem;
      padding: 0.95rem 1rem;
      background: var(--bg);
      border: 1px solid var(--line);
      color: var(--fg);
      border-radius: 2px;
      font-family: var(--font-sans);
      font-size: 1rem;
    }
    .form input:focus {
      outline: none;
      border-color: var(--accent-2);
      box-shadow: 0 0 0 3px rgba(78,205,255,0.18);
    }
    .form button {
      cursor: pointer;
      padding: 0.95rem 1.75rem;
      border: 1.5px solid var(--accent);
    }

    .form-msg {
      max-width: 32rem;
      margin: 1rem auto 0;
      min-height: 1.2em;
      font-size: 0.95rem;
      color: var(--turquoise, #4ecdff);
    }

    .promise {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 2rem 0;
    }
    .col-title {
      font-size: 1.4rem;
      margin: 0 0 1rem;
      color: var(--fg);
    }
    .col-title em {
      color: var(--magenta);
      font-style: italic;
    }
    .col ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .col li {
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--line-soft);
      color: var(--fg-muted);
      font-size: 1rem;
    }
    .col li:last-child { border-bottom: none; }
    .col li::before {
      content: "✓ ";
      color: var(--accent-2);
      font-weight: 700;
      margin-right: 0.4em;
    }
    .wont li::before {
      content: "✗ ";
      color: var(--fg-dim);
    }

    .signoff {
      padding: 3rem 0 1rem;
      text-align: center;
    }
    .mantra {
      font-family: var(--font-serif);
      font-size: 1.4rem;
      color: var(--fg-muted);
      line-height: 1.5;
      margin: 0;
    }
    .mantra em {
      color: var(--accent);
      font-style: italic;
    }

    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
      border: 0;
    }

    @media (min-width: 760px) {
      .promise {
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        padding: 3rem 0;
      }
    }
  </style>

  <script>
    const form = document.getElementById("email-signup") as HTMLFormElement | null;
    const msg = document.getElementById("form-msg");
    if (form && msg) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        msg.textContent = "Sending...";
        try {
          const res = await fetch(form.action, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(Object.fromEntries(fd)),
          });
          if (res.ok) {
            msg.textContent = "🎸 Welcome aboard. Check your inbox.";
            form.reset();
          } else {
            const data = await res.json().catch(() => ({}));
            msg.textContent = data.error || "Something went wrong. Try again?";
          }
        } catch {
          msg.textContent = "Network error. Try again?";
        }
      });
    }
  </script>
</BaseLayout>
