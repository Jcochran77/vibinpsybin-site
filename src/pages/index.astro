---
import BaseLayout from "../layouts/BaseLayout.astro";
import shows from "../data/shows.json";
import releases from "../data/releases.json";

const now = new Date();
const upcomingShows = shows
  .filter((s) => new Date(s.date) >= now)
  .sort((a, b) => +new Date(a.date) - +new Date(b.date));
const nextShow = upcomingShows[0];
const latestRelease = releases[0];

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}
---

<BaseLayout>
  <section class="hero">
    <h1>Vibin&rsquo; Psybin<br /><span class="amp">&amp;</span> the Sunlight Band</h1>
    <p class="tagline">
      Nashville. Psychedelic. Cosmic country. Direct from us to you.
    </p>
  </section>

  {nextShow && (
    <section class="card">
      <h2>Next show</h2>
      <p class="big">{formatDate(nextShow.date)}</p>
      <p><strong>{nextShow.venue}</strong> &middot; {nextShow.city}</p>
      {nextShow.notes && <p class="muted">{nextShow.notes}</p>}
      {nextShow.ticketUrl ? (
        <p><a class="btn" href={nextShow.ticketUrl}>Get tickets</a></p>
      ) : (
        <p><a href="/shows">See all shows &rarr;</a></p>
      )}
    </section>
  )}

  {latestRelease && (
    <section class="card">
      <h2>Latest release</h2>
      <p class="big">{latestRelease.title}</p>
      <p class="muted">{latestRelease.artist} &middot; {latestRelease.year}</p>
      <p><a href="/music">Listen &rarr;</a></p>
    </section>
  )}

  <section class="signup">
    <h2>Stay in the loop</h2>
    <p>
      New shows, new songs, new videos. No spam, no algorithm, no daily noise.
      One email when there&rsquo;s something worth telling you.
    </p>

    <form
      id="email-signup"
      action="/api/subscribe"
      method="POST"
      class="form"
    >
      <label for="email" class="sr-only">Email address</label>
      <input
        id="email"
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder="your@email.com"
      />
      <button type="submit">Sign up</button>
    </form>
    <p class="form-msg" id="form-msg" aria-live="polite"></p>
  </section>

  <style>
    .hero {
      padding: 3rem 0 2rem;
      text-align: center;
    }
    .hero h1 {
      font-size: 3rem;
      letter-spacing: 0.01em;
      margin: 0 0 0.5rem;
    }
    .hero .amp {
      color: var(--accent);
      font-style: italic;
    }
    .tagline {
      color: var(--fg-muted);
      font-size: 1.1rem;
      font-style: italic;
      max-width: 36rem;
      margin: 0.5rem auto 0;
    }
    .card {
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 1.5rem 2rem;
      margin: 2rem 0;
      background: var(--bg-alt);
    }
    .card h2 {
      margin-top: 0;
      color: var(--accent);
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }
    .big {
      font-size: 1.4rem;
      margin: 0.5rem 0;
    }
    .btn {
      display: inline-block;
      padding: 0.6rem 1.5rem;
      border: 1px solid var(--accent);
      color: var(--accent);
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.9rem;
      font-family: ui-sans-serif, system-ui, sans-serif;
    }
    .btn:hover {
      background: var(--accent);
      color: var(--bg);
      text-decoration: none;
    }
    .signup {
      padding: 3rem 0 1rem;
      text-align: center;
    }
    .signup p {
      max-width: 36rem;
      margin: 0.5rem auto 1.5rem;
      color: var(--fg-muted);
    }
    .form {
      display: flex;
      gap: 0.5rem;
      max-width: 30rem;
      margin: 0 auto;
      flex-wrap: wrap;
      justify-content: center;
    }
    .form input {
      flex: 1 1 18rem;
      padding: 0.75rem 1rem;
      background: var(--bg-alt);
      border: 1px solid var(--line);
      color: var(--fg);
      border-radius: 4px;
      font-family: inherit;
      font-size: 1rem;
    }
    .form input:focus {
      outline: none;
      border-color: var(--accent);
    }
    .form button {
      padding: 0.75rem 1.5rem;
      background: var(--accent);
      border: none;
      color: var(--bg);
      border-radius: 4px;
      font-family: ui-sans-serif, system-ui, sans-serif;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      cursor: pointer;
    }
    .form button:hover { background: var(--accent-dim); }
    .form-msg {
      max-width: 30rem;
      margin: 0.75rem auto 0;
      min-height: 1.2em;
      font-size: 0.9rem;
    }
    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
      border: 0;
    }
  </style>

  <script>
    const form = document.getElementById("email-signup") as HTMLFormElement | null;
    const msg = document.getElementById("form-msg");
    if (form && msg) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        msg.textContent = "Sending...";
        try {
          const res = await fetch(form.action, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(Object.fromEntries(fd)),
          });
          if (res.ok) {
            msg.textContent = "🎸 Welcome aboard. Check your inbox.";
            form.reset();
          } else {
            const data = await res.json().catch(() => ({}));
            msg.textContent = data.error || "Something went wrong. Try again?";
          }
        } catch {
          msg.textContent = "Network error. Try again?";
        }
      });
    }
  </script>
</BaseLayout>
