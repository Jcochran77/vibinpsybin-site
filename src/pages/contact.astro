---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import outdoorPhoto from "../assets/photos/outdoor-purple.jpg";
---

<BaseLayout title="Contact — Vibin' Psybin and the Sunlight Band">
  <section class="band page-hero">
    <div class="wrap-narrow">
      <p class="eyebrow">Say hi</p>
      <h1>Contact</h1>
      <p class="lead muted">
        Booking, press, collaborations, hellos. Drop a line.
      </p>
    </div>
  </section>

  <section class="band contact-section">
    <div class="wrap contact-grid">
      <div class="contact-photo">
        <Image
          src={outdoorPhoto}
          alt="Joe Psybin outdoors"
          widths={[400, 700, 1000]}
          sizes="(max-width: 760px) 90vw, 400px"
          class="photo"
        />
      </div>
      <form id="contact-form" action="/api/contact" method="POST" class="form">
        <label>
          <span class="label-text">Your name</span>
          <input name="name" type="text" required autocomplete="name" />
        </label>
        <label>
          <span class="label-text">Your email</span>
          <input name="email" type="email" required autocomplete="email" />
        </label>
        <label>
          <span class="label-text">What's up?</span>
          <textarea name="message" rows="6" required></textarea>
        </label>
        <button type="submit" class="btn btn-solid">Send message</button>
        <p class="form-msg" id="form-msg" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <style>
    .page-hero {
      padding: 4rem 0 2rem;
      text-align: center;
    }
    .lead {
      font-size: 1.1rem;
      max-width: 42rem;
      margin: 0.5rem auto 0;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
      align-items: start;
    }
    .contact-photo .photo {
      width: 100%;
      height: auto;
      border-radius: 3px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }
    .form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .label-text {
      color: var(--fg-muted);
      font-family: var(--font-sans);
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      margin-bottom: 0.35rem;
      display: block;
    }
    .form input, .form textarea {
      width: 100%;
      padding: 0.85rem 1rem;
      background: var(--bg-alt);
      border: 1px solid var(--line);
      color: var(--fg);
      border-radius: 2px;
      font-family: var(--font-sans);
      font-size: 1rem;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .form textarea {
      resize: vertical;
      min-height: 8rem;
    }
    .form input:focus, .form textarea:focus {
      outline: none;
      border-color: var(--accent-2);
      box-shadow: 0 0 0 3px rgba(78,205,196,0.15);
    }
    .form button {
      align-self: flex-start;
      cursor: pointer;
      border: 1.5px solid var(--accent);
    }
    .form-msg {
      min-height: 1.2em;
      font-size: 0.9rem;
      color: var(--turquoise);
      margin: 0;
    }

    @media (min-width: 760px) {
      .contact-grid {
        grid-template-columns: 1fr 1.2fr;
        gap: 4rem;
      }
    }
  </style>

  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const msg = document.getElementById("form-msg");
    if (form && msg) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        msg.textContent = "Sending...";
        try {
          const res = await fetch(form.action, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(Object.fromEntries(fd)),
          });
          if (res.ok) {
            msg.textContent = "✨ Thanks — message sent.";
            form.reset();
          } else {
            msg.textContent = "Something went wrong. Try again?";
          }
        } catch {
          msg.textContent = "Network error. Try again?";
        }
      });
    }
  </script>
</BaseLayout>
