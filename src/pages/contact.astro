---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import outdoorPhoto from "../assets/photos/outdoor-purple.jpg";

// Optional pre-fill from query string (?re=Song+Name) — used by Music page
// per-song "Drop Joe a line about this song →" links.
const re = Astro.url.searchParams.get("re");
const initialMessage = re ? `Re: ${re}\n\n` : "";
const initialKind = re ? "song-feedback" : "hello";

// Cloudflare Turnstile site key. Public — safe to expose at build time.
// If unset (dev/preview without keys), the widget is omitted and the
// server-side handler falls back to its graceful skip path.
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<BaseLayout
  title="Say hey — Vibin' Psybin and the Sunlight Band"
  description="Drop us a line. We read every one. Sometimes we even write back."
>
  <section class="band page-hero">
    <div class="wrap-narrow">
      <p class="eyebrow">Say hey 👋</p>
      <h1>Drop us a line.</h1>
      <p class="lead">
        We read every one. Sometimes we even write back.
      </p>
    </div>
  </section>

  <section class="band contact-section">
    <div class="wrap contact-grid">
      <div class="contact-photo">
        <Image
          src={outdoorPhoto}
          alt="Joe Psybin outdoors"
          widths={[400, 700, 1000]}
          sizes="(max-width: 760px) 90vw, 400px"
          class="photo"
        />
        <p class="photo-caption">
          🎸 Joe, in his backyard in Nashville
        </p>
        <p class="production-link">
          Looking to record? <a href="/producer">Production work →</a>
        </p>
      </div>

      <form id="contact-form" action="/api/contact" method="POST" class="form">
        <label class="field">
          <span class="label-text">What kind of message is this?</span>
          <select name="kind" id="kind">
            <option value="hello" selected={initialKind === "hello"}>Just saying hi 👋</option>
            <option value="song-feedback" selected={initialKind === "song-feedback"}>Thoughts on a song 🎵</option>
            <option value="booking">Show booking 🎤</option>
            <option value="production">Production work 🎛️</option>
            <option value="press">Press / interviews 📰</option>
            <option value="other">Something else 🎨</option>
          </select>
        </label>

        <label class="field">
          <span class="label-text">Who&rsquo;s this?</span>
          <input name="name" type="text" required autocomplete="name" placeholder="Your name" />
        </label>

        <label class="field">
          <span class="label-text">Where can we find you?</span>
          <input name="email" type="email" required autocomplete="email" placeholder="your@email.com" />
        </label>

        <label class="field">
          <span class="label-text">What&rsquo;s on your mind?</span>
          <textarea name="message" rows="7" required placeholder="..." set:html={initialMessage}></textarea>
        </label>

        {/* Honeypot field — hidden from humans, irresistible to spam bots.
            If anything ends up in here on submit, the server silently 200s
            without delivering. Belt-and-suspenders hiding: CSS class +
            inline display:none + aria-hidden + tabindex=-1 + autocomplete=off. */}
        <div class="hp-field" aria-hidden="true">
          <label>
            Website (leave blank)
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
          </label>
        </div>

        {turnstileSiteKey && (
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>
        )}

        <button type="submit" class="btn btn-solid">Send it</button>
        <p class="form-msg" id="form-msg" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <section class="band signoff">
    <div class="wrap-narrow center">
      <p class="mantra">
        No bots. No auto-replies.
        <br/><em>Just a guy reading a message.</em>
      </p>
    </div>
  </section>

  <style>
    .page-hero {
      padding: 4rem 0 2rem;
      text-align: center;
    }
    .lead {
      font-size: 1.2rem;
      color: var(--fg-muted);
      font-style: italic;
      max-width: 36rem;
      margin: 0.5rem auto 0;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      align-items: start;
    }
    .contact-photo {
      text-align: center;
    }
    .contact-photo .photo {
      width: 100%;
      height: auto;
      border-radius: 3px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }
    .photo-caption {
      margin: 0.75rem 0 0;
      font-size: 0.9rem;
      color: var(--fg-muted);
      font-style: italic;
    }
    .production-link {
      margin: 1.25rem 0 0;
      font-size: 0.9rem;
      color: var(--fg-dim);
    }
    .production-link a {
      color: var(--fg-muted);
      border-bottom: 1px solid var(--line);
      padding-bottom: 1px;
    }
    .production-link a:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }

    .form {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .field {
      display: flex;
      flex-direction: column;
    }
    .label-text {
      color: var(--fg-muted);
      font-family: var(--font-sans);
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      margin-bottom: 0.5rem;
    }
    .form input,
    .form textarea,
    .form select {
      width: 100%;
      padding: 0.95rem 1rem;
      background: var(--bg-alt);
      border: 1px solid var(--line);
      color: var(--fg);
      border-radius: 2px;
      font-family: var(--font-sans);
      font-size: 1rem;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .form select {
      appearance: none;
      -webkit-appearance: none;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path d='M1 1l5 5 5-5' fill='none' stroke='%23b9abc6' stroke-width='2'/></svg>");
      background-repeat: no-repeat;
      background-position: right 1rem center;
      padding-right: 2.5rem;
      cursor: pointer;
    }
    .form textarea {
      resize: vertical;
      min-height: 9rem;
      line-height: 1.55;
    }
    .form input:focus,
    .form textarea:focus,
    .form select:focus {
      outline: none;
      border-color: var(--accent-2);
      box-shadow: 0 0 0 3px rgba(78,205,255,0.18);
    }
    .form button {
      align-self: flex-start;
      cursor: pointer;
      border: 1.5px solid var(--accent);
      padding: 0.95rem 2rem;
      font-size: 0.9rem;
    }
    .form-msg {
      min-height: 1.2em;
      font-size: 0.95rem;
      color: var(--electric);
      margin: 0;
    }

    /* Honeypot — invisible to humans, present in the DOM for bots. */
    .hp-field {
      position: absolute !important;
      left: -10000px !important;
      top: auto !important;
      width: 1px !important;
      height: 1px !important;
      overflow: hidden !important;
      display: none !important;
      opacity: 0 !important;
      pointer-events: none !important;
    }

    .signoff {
      padding: 3rem 0 1rem;
      text-align: center;
    }
    .center { text-align: center; }
    .mantra {
      font-family: var(--font-serif);
      font-size: 1.35rem;
      color: var(--fg-muted);
      line-height: 1.5;
      margin: 0;
    }
    .mantra em {
      color: var(--accent);
      font-style: italic;
    }

    @media (min-width: 760px) {
      .contact-grid {
        grid-template-columns: 1fr 1.2fr;
        gap: 4rem;
      }
    }
  </style>

  {turnstileSiteKey && (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}

  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const msg = document.getElementById("form-msg");
    if (form && msg) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        // FormData picks up the Turnstile widget's auto-injected
        // hidden input named `cf-turnstile-response`, so the JSON body
        // includes it without us having to thread it manually.
        const fd = new FormData(form);
        msg.textContent = "Sending...";
        try {
          const res = await fetch(form.action, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(Object.fromEntries(fd)),
          });
          if (res.ok) {
            msg.textContent = "🎸 Got it — talk soon.";
            form.reset();
            // Reset Turnstile so the next submit gets a fresh token.
            const turnstile = (window as any).turnstile;
            if (turnstile && typeof turnstile.reset === "function") {
              try { turnstile.reset(); } catch {}
            }
          } else if (res.status === 403) {
            msg.textContent = "Verification failed. Please try again.";
            const turnstile = (window as any).turnstile;
            if (turnstile && typeof turnstile.reset === "function") {
              try { turnstile.reset(); } catch {}
            }
          } else {
            msg.textContent = "Something went wrong. Try again?";
          }
        } catch {
          msg.textContent = "Network error. Try again?";
        }
      });
    }
  </script>
</BaseLayout>
