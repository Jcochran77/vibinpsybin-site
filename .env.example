# Copy to .env for local dev. The real values live in:
#   - /Volumes/LaCie/.openclaw/workspace/.secrets/music.env (on the workspace machine)
#   - Cloudflare Pages environment variables (production)

# Bandsintown public API app id. Used at BUILD time to pull show data.
BANDSINTOWN_APP_ID=

# Buttondown API key. Used at RUNTIME by /api/subscribe serverless function.
BUTTONDOWN_API_KEY=

# Resend API key. Used at RUNTIME by /api/contact to email Say Hey form
# submissions to vibinpsybin@gmail.com. Required — without it the contact
# form returns HTTP 500.
RESEND_API_KEY=

# Optional. Defaults to "Vibin' Psybin <onboarding@resend.dev>" (Resend's
# shared sandbox sender) until sayhey@vibinpsybin.band has SPF/DKIM set up
# and the domain is verified in Resend.
RESEND_FROM_ADDRESS=

# Optional. Defaults to vibinpsybin@gmail.com.
RESEND_TO_ADDRESS=

# Optional. Telegram bot token for the secondary best-effort ping to the
# Music group chat. If unset, the email still goes out and the Telegram
# ping is silently skipped.
TELEGRAM_BOT_TOKEN=

# Optional. Defaults to -5203788960 (the Vibin' Psybin Music group).
TELEGRAM_CHAT_ID=

# Cloudflare Turnstile keys for the Say Hey form anti-bot defense.
# Get them from Cloudflare dashboard → Turnstile → Add site (vibinpsybin.band, Mode: Managed).
#
# PUBLIC_ prefix exposes the site key to the client at BUILD time (Astro convention).
# Public/safe — anyone visiting the page sees this in HTML.
PUBLIC_TURNSTILE_SITE_KEY=

# Server-side secret for siteverify. Used at RUNTIME by /api/contact.
# If unset, the handler logs a warning and skips Turnstile verification
# (so dev/preview without keys still works — honeypot still active).
TURNSTILE_SECRET_KEY=

